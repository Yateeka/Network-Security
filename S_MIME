import os, datetime, uuid
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.primitives.asymmetric import rsa, padding
from cryptography.hazmat.primitives.ciphers.aead import AESGCM
from cryptography import x509
from cryptography.x509 import NameOID


AES_MODE = "AES-GCM (128-bit)"
HASH_FUNC = "SHA-256"
RSA_PAD = "RSA-OAEP"
SIG_PAD = "RSA-PSS"

# KEY GENERATION (PKI simulation)
def gen_keys(name):
    priv = rsa.generate_private_key(public_exponent=65537, key_size=2048)
    pub = priv.public_key()

    cert = (x509.CertificateBuilder()
        .subject_name(x509.Name([x509.NameAttribute(NameOID.COMMON_NAME, name)]))
        .issuer_name(x509.Name([x509.NameAttribute(NameOID.COMMON_NAME, name)]))
        .public_key(pub)
        .serial_number(x509.random_serial_number())
        .not_valid_before(datetime.datetime.utcnow())
        .not_valid_after(datetime.datetime.utcnow() + datetime.timedelta(days=365))
        .sign(priv, hashes.SHA256())
    )

    return priv, pub, cert

# SIGNATURE MODULE
def sign(msg, sk):
    print("\n[STEP 1: SIGN]")
    print("Hash:", HASH_FUNC, "Sig:", SIG_PAD)

    return sk.sign(
        msg,
        padding.PSS(
            mgf=padding.MGF1(hashes.SHA256()),
            salt_length=padding.PSS.MAX_LENGTH
        ),
        hashes.SHA256()
    )

# ENCRYPTION MODULE (AES)
def encrypt(msg):
    print("\n[STEP 2: AES ENCRYPT]")
    print("Algorithm:", AES_MODE)

    key = AESGCM.generate_key(bit_length=128)
    aes = AESGCM(key)
    nonce = os.urandom(12)

    return key, nonce, aes.encrypt(nonce, msg, None)

# KEY EXCHANGE MODULE (RSA)
def wrap_key(key, pub):
    print("\n[STEP 3: RSA KEY WRAP]")
    print("Padding:", RSA_PAD)

    return pub.encrypt(
        key,
        padding.OAEP(
            mgf=padding.MGF1(hashes.SHA256()),
            algorithm=hashes.SHA256(),
            label=None
        )
    )


# VERIFICATION MODULE
def verify(msg, sig, pub):
    print("\n[STEP 7: VERIFY SIGNATURE]")

    try:
        pub.verify(
            sig,
            msg,
            padding.PSS(
                mgf=padding.MGF1(hashes.SHA256()),
                salt_length=padding.PSS.MAX_LENGTH
            ),
            hashes.SHA256()
        )
        print("SIGNATURE VALID")
        return True

    except:
        print("SIGNATURE FAILED → sender not trusted")
        return False

# SEND WORKFLOW

def send(msg, s_priv, r_pub):
    print("\n===== S/MIME SEND: Sign → Encrypt → Wrap =====")

    mid = str(uuid.uuid4()).encode()
    full = mid + b"||" + msg

    sig = sign(full, s_priv)
    key, nonce, cipher = encrypt(full)
    ek = wrap_key(key, r_pub)

    print("\n[PACKET CREATED]")
    print("MsgID:", mid.decode())
    print("Cipher size:", len(cipher))

    return {
        "id": mid,
        "cipher": cipher,
        "nonce": nonce,
        "ek": ek,
        "sig": sig
    }



# RECEIVE WORKFLOW
def receive(pkt, r_priv, s_pub, seen):
    print("\n===== S/MIME RECEIVE: Unwrap → Decrypt → Verify =====")

    try:
        # FIXED: correct RSA unwrap usage
        key = r_priv.decrypt(
            pkt["ek"],
            padding.OAEP(
                mgf=padding.MGF1(hashes.SHA256()),
                algorithm=hashes.SHA256(),
                label=None
            )
        )

        msg = AESGCM(key).decrypt(pkt["nonce"], pkt["cipher"], None)
        mid, m = msg.split(b"||", 1)

        print("Recovered:", m)
        print("MsgID:", mid.decode())

        # Replay protection
        if mid in seen:
            print("REPLAY ATTACK DETECTED")
            return False
        seen.add(mid)

        # Signature check (FIXED logic: verify FULL message, not raw)
        return verify(msg, pkt["sig"], s_pub)

    except:
        print("DECRYPTION FAILED → tampering or corruption")
        return False
 
# DEMO

if __name__ == "__main__":

    sp, s_pub, _ = gen_keys("Sender")
    rp, r_pub, _ = gen_keys("Receiver")
    fake_priv, fake_pub, _ = gen_keys("Attacker")

    seen = set()
    msg = b"Secure enterprise email message"

    print("\n NORMAL FLOW")
    pkt = send(msg, sp, r_pub)
    receive(pkt, rp, s_pub, seen)

    print("\n TAMPERING ATTACK ")
    bad = pkt.copy()
    c = bytearray(pkt["cipher"])
    c[0] ^= 1
    bad["cipher"] = bytes(c)
    receive(bad, rp, s_pub, seen)

    print("\n WRONG KEY ATTACK ")
    receive(pkt, rp, fake_pub, seen)

    print("\n REPLAY ATTACK ")
    receive(pkt, rp, s_pub, seen)
